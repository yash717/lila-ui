# Copy to .env for local dev. Vite only exposes variables prefixed with VITE_.
# Production: set these when running `bun run build` (or use .env.production on the build host).

# Nakama HTTP + WebSocket endpoint (same host/port as nebula-server docker maps 7350)
VITE_NAKAMA_HOST=127.0.0.1
VITE_NAKAMA_PORT=7350

# Must match NAKAMA_SERVER_KEY / socket.server_key on the Nakama server
VITE_NAKAMA_SERVER_KEY=nebula-strike-dev-key

# true when the page is served over HTTPS and Nakama is reached with wss (TLS in front of Nakama)
VITE_NAKAMA_USE_SSL=false
